# ============================================================
# LDU GRANT OPERATIONS — ENVIRONMENT CONFIGURATION
# ============================================================
# INSTRUCTIONS:
# 1. Copy this file: cp .env.example .env
# 2. Fill in each value below
# 3. NEVER commit the .env file to git (it's in .gitignore)
# ============================================================

# --- ANTHROPIC (Claude AI) ---
# Get your key at: https://console.anthropic.com/settings/keys
# Click "Create Key" → copy the key that starts with "sk-ant-"
ANTHROPIC_API_KEY=sk-ant-your-key-here

# --- AIRTABLE ---
# Get your token at: https://airtable.com/create/tokens
# Click "Create new token" → Give it these scopes:
#   data.records:read, data.records:write, schema.bases:read, schema.bases:write
# Then add your LDU Grant Ops base to the token's access list
AIRTABLE_API_TOKEN=pat_your-token-here

# Your Airtable Base ID (found in the URL when you open your base)
# It looks like: appXXXXXXXXXXXXXX
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX

# --- GOOGLE DRIVE ---
# Follow the setup guide in SETUP_GUIDE.md Section 3 for Google credentials
# You'll download a JSON file — put the path here
GOOGLE_CREDENTIALS_PATH=config/google_credentials.json

# The ID of your LDU Grant Operations shared drive folder
# (found in the URL when you open the folder in Google Drive)
GOOGLE_DRIVE_FOLDER_ID=your-folder-id-here

# --- MAKE.COM ---
# These are the webhook URLs for your Make.com scenarios
# You'll create these in Make.com — see SETUP_GUIDE.md Section 4
MAKE_WEBHOOK_PROSPECT_INTAKE=https://hook.us1.make.com/your-webhook-1
MAKE_WEBHOOK_DEADLINE_SYNC=https://hook.us1.make.com/your-webhook-2
MAKE_WEBHOOK_SUBMISSION_FOLLOWUP=https://hook.us1.make.com/your-webhook-3
MAKE_WEBHOOK_REPORT_ALERT=https://hook.us1.make.com/your-webhook-4
MAKE_WEBHOOK_AWARD_ONBOARD=https://hook.us1.make.com/your-webhook-5
MAKE_WEBHOOK_DECLINE_RECOVERY=https://hook.us1.make.com/your-webhook-6
MAKE_WEBHOOK_WEEKLY_SUMMARY=https://hook.us1.make.com/your-webhook-7

# --- INSTRUMENTL ---
# If Instrumentl offers API access, add the key here
# Otherwise, alerts flow through Make.com webhooks
INSTRUMENTL_API_KEY=your-key-if-available

# --- POKE AI ---
# Poke webhook or API for sending SMS briefings
POKE_WEBHOOK_URL=your-poke-webhook-url

# --- GENERAL ---
# Timezone for scheduling (Los Angeles)
TIMEZONE=America/Los_Angeles

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# CEO phone/contact for Poke alerts
CEO_CONTACT=kika-keith-contact-here

# Implementation Lead contact for Poke alerts
IMPL_LEAD_CONTACT=kika-howze-contact-here
